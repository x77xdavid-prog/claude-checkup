# 키 '이름'만 적는다. 실제 값은 .env 에 (.env 는 커밋 금지)
# 배포 도메인(OG·sitemap·robots·canonical 기준). 미설정 시 http://localhost:3000
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# 뉴스레터 발신자 신원(정보통신망법 표기). 미설정 시 Resend 테스트 발신자(onboarding@resend.dev)로 폴백.
NEWSLETTER_FROM=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Google AdSense Publisher ID (ca-pub-XXXX). 비우면 광고·스크립트 미로드(사이트 정상).
# 실값 예: ca-pub-6683761499521589 (공개값 — ads.txt·광고태그에 노출되는 ID)
NEXT_PUBLIC_ADSENSE_ID=
# 영속 레이트리밋(Upstash Redis REST). 둘 다 있으면 서버리스 다중 인스턴스에도 카운트 유지, 없으면 인메모리 폴백.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
